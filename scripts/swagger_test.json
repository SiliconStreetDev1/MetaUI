{
    "openapi": "3.0.0",
    "info": {
      "title": "Petstore API",
      "version": "1.0.0"
    },
    "components": {
      "schemas": {
        "Pet": {
          "type": "object",
          "required": [
            "name",
            "photoUrls"
          ],
          "properties": {
            "id": {
              "type": "integer",
              "format": "int64",
              "description": "Unique ID"
            },
            "name": {
              "type": "string",
              "example": "doggie",
              "maxLength": 50,
              "pattern": "^[a-zA-Z]+$"
            },
            "photoUrls": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "category": {
              "$ref": "#/components/schemas/Category"
            },
            "status": {
              "type": "string",
              "description": "pet status in the store",
              "enum": [
                "available",
                "pending",
                "sold"
              ]
            }
          }
        },
        "Category": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "id": {
              "type": "integer",
              "format": "int64"
            },
            "name": {
              "type": "string"
            }
          }
        }
      }
    }
  }
