{
  "title": "Customer Profile",
  "type": "object",
  "properties": {
    "CustomerName": {
      "type": "string",
      "required": true,
      "maxLength": 50,
      "ui": {
        "label": "Customer Name",
        "isKey": true,
        "group": "General Information"
      }
    },
    "IsActive": {
      "type": "boolean",
      "ui": {
        "label": "Account Active",
        "group": "General Information",
        "widget": "switch"
      }
    },
    "Comments": {
      "type": "string",
      "ui": {
        "label": "Additional Notes",
        "group": "General Information",
        "widget": "textArea",
        "rows": 4,
        "fullWidth": true
      }
    },
    "AccountType": {
      "type": "string",
      "required": true,
      "valueHelp": [
        { "key": "BASIC", "text": "Basic Plan" },
        { "key": "PREMIUM", "text": "Premium Plan" },
        { "key": "CORPORATE", "text": "Corporate Plan" }
      ],
      "ui": {
        "label": "Account Type",
        "group": "General Information",
        "widget": "select"
      }
    },
    "CreditLimit": {
      "type": "number",
      "required": true,
      "scale": 2,
      "ui": {
        "label": "Credit Limit (USD)",
        "group": "Financials",
        "visibleOn": "$root.IsActive === true"
      }
    },
    "CreationDate": {
      "type": "date",
      "ui": {
        "label": "Creation Date",
        "readOnly": true,
        "group": "System Logs"
      }
    },
    "Attachment": {
      "type": "string",
      "ui": {
        "label": "Supporting Document",
        "group": "Enterprise Controls",
        "widget": "fileUploader"
      }
    },
    "AccessRegions": {
      "type": "array",
      "enum": ["North America", "Europe", "Asia", "Oceania"],
      "ui": {
        "label": "Access Regions",
        "group": "Enterprise Controls",
        "widget": "multiSelect"
      }
    },
    "Discount": {
      "type": "number",
      "minimum": 0,
      "maximum": 50,
      "multipleOf": 5,
      "ui": {
        "label": "Discount % (Max 50%)",
        "group": "Enterprise Controls",
        "widget": "slider"
      }
    },
    "ClientRating": {
      "type": "number",
      "maximum": 5,
      "ui": {
        "label": "Client Rating",
        "group": "Enterprise Controls",
        "widget": "rating"
      }
    },
    "AlertMsg": {
      "type": "string",
      "ui": {
        "widget": "messageStrip",
        "group": "Enterprise Controls"
      }
    },
    "Website": {
      "type": "string",
      "ui": {
        "label": "Corporate Website",
        "group": "Validators",
        "validators": ["url"]
      }
    },
    "IBAN": {
      "type": "string",
      "ui": {
        "label": "Bank Account (IBAN)",
        "group": "Validators",
        "validators": ["iban"]
      }
    },
    "LicenseCode": {
      "type": "string",
      "ui": {
        "label": "License Code (ABC-123)",
        "group": "Validators",
        "validators": [{"name": "pattern", "args": "^[A-Z]{3}-\\d{3}$"}, {"name": "minLength", "args": 7}]
      }
    },
    "SupportPhone": {
      "type": "string",
      "ui": {
        "label": "Support Phone",
        "group": "Formatters",
        "formatter": "phone"
      }
    },
    "ActionRow": {
      "type": "string",
      "ui": {
        "label": "Navigate to Corporate",
        "group": "Formatters",
        "widget": "urlButton",
        "args": "https://sap.com"
      }
    },
    "ContactEmail": {
      "type": "string",
      "required": true,
      "ui": {
        "label": "Contact Email",
        "group": "Plugin Demonstrations",
        "validators": ["email"]
      }
    },
    "Revenue": {
      "type": "number",
      "ui": {
        "label": "Projected Revenue",
        "group": "Plugin Demonstrations",
        "formatter": "currency"
      }
    },
    "LiveCountries": {
      "type": "string",
      "ui": {
        "label": "Live Country Search (Async)",
        "group": "Plugin Demonstrations",
        "widget": "remoteDropdown"
      }
    },
    "ResetData": {
      "type": "string",
      "ui": {
        "label": "Danger Zone",
        "group": "Plugin Demonstrations",
        "widget": "clearButton"
      }
    },
    "MeetingTime": {
      "type": "string",
      "required": true,
      "ui": {
        "label": "Meeting Time",
        "group": "System Logs",
        "widget": "time"
      }
    },
    "LastLogin": {
      "type": "string",
      "ui": {
        "label": "Last Login Timestamp",
        "readOnly": true,
        "group": "System Logs",
        "widget": "datetime"
      }
    },
    "Contacts": {
      "type": "array",
      "ui": {
        "label": "Authorized Contacts"
      },
      "items": {
        "type": "object",
        "properties": {
          "ContactID": {
            "type": "string",
            "required": true,
            "ui": {
              "label": "ID",
              "isKey": true,
              "readOnly": true
            }
          },
          "FullName": {
            "type": "string",
            "required": true,
            "maxLength": 100,
            "ui": {
              "label": "Full Name"
            }
          },
          "Role": {
            "type": "string",
            "required": true,
            "valueHelp": [
              { "key": "ADMIN", "text": "Administrator" },
              { "key": "BILLING", "text": "Billing Contact" },
              { "key": "TECH", "text": "Technical Support" }
            ],
            "ui": {
              "label": "Role",
              "widget": "select"
            }
          },
          "HasPortalAccess": {
            "type": "boolean",
            "ui": {
              "label": "Portal Access"
            }
          }
        }
      }
    }
  }
}
