{
  "title": "Customer Profile",
  "type": "object",
  "properties": {
    "CustomerName": {
      "type": "string",
      "required": true,
      "maxLength": 50,
      "ui": {
        "label": "Customer Name",
        "isKey": true
      }
    },
    "IsActive": {
      "type": "boolean",
      "ui": {
        "label": "Account Active",
        "widget": "switch"
      }
    },
    "Comments": {
      "type": "string",
      "ui": {
        "label": "Additional Notes",
        "widget": "textArea",
        "rows": 4,
        "fullWidth": true
      }
    },
    "AccountType": {
      "type": "string",
      "required": true,
      "valueHelp": [
        {
          "key": "BASIC",
          "text": "Basic Plan"
        },
        {
          "key": "PREMIUM",
          "text": "Premium Plan"
        },
        {
          "key": "CORPORATE",
          "text": "Corporate Plan"
        }
      ],
      "ui": {
        "label": "Account Type",
        "widget": "select"
      }
    },
    "CreditLimit": {
      "type": "number",
      "required": true,
      "scale": 2,
      "ui": {
        "label": "Credit Limit (USD)",
        "visibleOn": "$root.IsActive === true"
      }
    },
    "CreationDate": {
      "type": "date",
      "ui": {
        "label": "Creation Date",
        "readOnly": true
      }
    },
    "Attachment": {
      "type": "string",
      "ui": {
        "label": "Supporting Document",
        "widget": "fileUploader"
      }
    },
    "AccessRegions": {
      "type": "array",
      "enum": [
        "North America",
        "Europe",
        "Asia",
        "Oceania"
      ],
      "ui": {
        "label": "Access Regions",
        "widget": "multiSelect"
      }
    },
    "Discount": {
      "type": "number",
      "minimum": 0,
      "maximum": 50,
      "multipleOf": 5,
      "ui": {
        "label": "Discount % (Max 50%)",
        "widget": "slider"
      }
    },
    "ClientRating": {
      "type": "number",
      "maximum": 5,
      "ui": {
        "label": "Client Rating",
        "widget": "rating"
      }
    },
    "AlertMsg": {
      "type": "string",
      "ui": {
        "widget": "messageStrip"
      }
    },
    "Website": {
      "type": "string",
      "ui": {
        "label": "Corporate Website",
        "validators": [
          "url"
        ]
      }
    },
    "IBAN": {
      "type": "string",
      "ui": {
        "label": "Bank Account (IBAN)",
        "validators": [
          "iban"
        ]
      }
    },
    "LicenseCode": {
      "type": "string",
      "ui": {
        "label": "License Code (ABC-123)",
        "validators": [
          {
            "name": "pattern",
            "args": "^[A-Z]{3}-\\d{3}$"
          },
          {
            "name": "minLength",
            "args": 7
          }
        ]
      }
    },
    "SupportPhone": {
      "type": "string",
      "ui": {
        "label": "Support Phone",
        "formatter": "phone"
      }
    },
    "ActionRow": {
      "type": "string",
      "ui": {
        "label": "Navigate to Corporate",
        "widget": "urlButton",
        "args": "https://sap.com"
      }
    },
    "ContactEmail": {
      "type": "string",
      "required": true,
      "ui": {
        "label": "Contact Email",
        "validators": [
          "email"
        ]
      }
    },
    "Revenue": {
      "type": "number",
      "ui": {
        "label": "Projected Revenue",
        "formatter": "currency"
      }
    },
    "LiveCountries": {
      "type": "string",
      "ui": {
        "label": "Live Country Search (Async)",
        "widget": "remoteDropdown"
      }
    },
    "ResetData": {
      "type": "string",
      "ui": {
        "label": "Danger Zone",
        "widget": "clearButton"
      }
    },
    "MeetingTime": {
      "type": "string",
      "required": true,
      "ui": {
        "label": "Meeting Time",
        "widget": "time"
      }
    },
    "LastLogin": {
      "type": "string",
      "ui": {
        "label": "Last Login Timestamp",
        "readOnly": true,
        "widget": "datetime"
      }
    },
    "Contacts": {
      "type": "array",
      "ui": {
        "label": "Authorized Contacts"
      },
      "items": {
        "type": "object",
        "properties": {
          "ContactID": {
            "type": "string",
            "required": true,
            "ui": {
              "label": "ID",
              "isKey": true,
              "readOnly": true
            }
          },
          "FullName": {
            "type": "string",
            "required": true,
            "maxLength": 100,
            "ui": {
              "label": "Full Name"
            }
          },
          "Role": {
            "type": "string",
            "required": true,
            "valueHelp": [
              {
                "key": "ADMIN",
                "text": "Administrator"
              },
              {
                "key": "BILLING",
                "text": "Billing Contact"
              },
              {
                "key": "TECH",
                "text": "Technical Support"
              }
            ],
            "ui": {
              "label": "Role",
              "widget": "select"
            }
          },
          "HasPortalAccess": {
            "type": "boolean",
            "ui": {
              "label": "Portal Access"
            }
          }
        }
      },
      "uiLayout": [
        {
          "type": "Control",
          "scope": "#/properties/ContactID"
        },
        {
          "type": "Control",
          "scope": "#/properties/FullName"
        },
        {
          "type": "Control",
          "scope": "#/properties/Role"
        },
        {
          "type": "Control",
          "scope": "#/properties/HasPortalAccess"
        }
      ]
    }
  },
  "uiLayout": [
    {
      "type": "Group",
      "label": "General Information",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/CustomerName"
        },
        {
          "type": "Control",
          "scope": "#/properties/IsActive"
        },
        {
          "type": "Control",
          "scope": "#/properties/Comments"
        },
        {
          "type": "Control",
          "scope": "#/properties/AccountType"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Financials",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/CreditLimit"
        }
      ]
    },
    {
      "type": "Group",
      "label": "System Logs",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/CreationDate"
        },
        {
          "type": "Control",
          "scope": "#/properties/MeetingTime"
        },
        {
          "type": "Control",
          "scope": "#/properties/LastLogin"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Enterprise Controls",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/Attachment"
        },
        {
          "type": "Control",
          "scope": "#/properties/Discount"
        },
        {
          "type": "Control",
          "scope": "#/properties/ClientRating"
        },
        {
          "type": "Control",
          "scope": "#/properties/AlertMsg"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Validators",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/Website"
        },
        {
          "type": "Control",
          "scope": "#/properties/IBAN"
        },
        {
          "type": "Control",
          "scope": "#/properties/LicenseCode"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Formatters",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/SupportPhone"
        },
        {
          "type": "Control",
          "scope": "#/properties/ActionRow"
        }
      ]
    },
    {
      "type": "Group",
      "label": "Plugin Demonstrations",
      "elements": [
        {
          "type": "Control",
          "scope": "#/properties/ContactEmail"
        },
        {
          "type": "Control",
          "scope": "#/properties/Revenue"
        },
        {
          "type": "Control",
          "scope": "#/properties/LiveCountries"
        },
        {
          "type": "Control",
          "scope": "#/properties/ResetData"
        }
      ]
    },
    {
      "type": "Control",
      "scope": "#/properties/AccessRegions"
    },
    {
      "type": "Control",
      "scope": "#/properties/Contacts"
    }
  ]
}