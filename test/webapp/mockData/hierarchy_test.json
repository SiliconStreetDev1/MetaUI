{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Deep Hierarchy & ID Collision Test",
    "description": "Tests ID scoping across multiple cloned forms in a table, containing hardware controls.",
    "type": "array",
    "uiLayout": [
        { "type": "Control", "scope": "#/properties/id", "label": "Record ID" },
        { "type": "Control", "scope": "#/properties/status", "label": "Status" },
        { "type": "Control", "scope": "#/properties/inspectionData", "label": "Inspection Details" }
    ],
    "items": {
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "ui": { "label": "Record ID", "readOnly": true }
            },
            "status": {
                "type": "string",
                "ui": {
                    "label": "Status",
                    "widget": "dropdown",
                    "options": [
                        { "key": "pending", "text": "Pending" },
                        { "key": "active", "text": "Active" }
                    ]
                }
            },
            "inspectionData": {
                "type": "object",
                "title": "Inspection Details",
                "layoutStrategy": "form",
                "uiLayout": [
                    { "type": "Control", "scope": "#/properties/sitePhoto" },
                    { "type": "Control", "scope": "#/properties/inspectorSignature" },
                    { "type": "Control", "scope": "#/properties/barcodeId" }
                ],
                "properties": {
                    "sitePhoto": {
                        "type": "string",
                        "ui": {
                            "label": "Site Photo (Camera)",
                            "widget": "camera"
                        }
                    },
                    "inspectorSignature": {
                        "type": "string",
                        "ui": {
                            "label": "Sign Off (Signature)",
                            "widget": "signature"
                        }
                    },
                    "barcodeId": {
                        "type": "string",
                        "ui": {
                            "label": "Asset Tag (Barcode)",
                            "widget": "scanner"
                        }
                    }
                }
            }
        }
    }
}
