{
    "type": "object",
    "uiLayout": [
        {
            "type": "Group",
            "label": "MetaUI Generated Form",
            "elements": [
                { "type": "Control", "scope": "#/properties/ProjectName" },
                { "type": "Control", "scope": "#/properties/Budget" },
                { "type": "Control", "scope": "#/properties/Country" },
                { "type": "Control", "scope": "#/properties/LiveCountrySearch" }
            ]
        },
        {
            "type": "Control",
            "scope": "#/properties/TeamMembers"
        }
    ],
    "properties": {
        "ProjectName": {
            "type": "string",
            "ui": { "label": "Project Name" }
        },
        "Budget": {
            "type": "number",
            "ui": { "label": "Project Budget" }
        },
        "Country": {
            "type": "string",
            "ui": { "label": "Project Country", "widget": "remoteDropdown" },
            "valueHelp": {
                "url": "mockData/countries.json",
                "keyPath": "id",
                "textPath": "name"
            }
        },
        "LiveCountrySearch": {
            "type": "string",
            "ui": { "label": "Live Country Search (Async)", "widget": "liveSearch" },
            "valueHelp": {
                "url": "mockData/countries.json",
                "keyPath": "id",
                "textPath": "name"
            }
        },
        "TeamMembers": {
            "type": "array",
            "ui": { "label": "Team Members" },
            "items": {
                "type": "object",
                "uiLayout": [
                    { "type": "Control", "scope": "#/properties/Name" },
                    { "type": "Control", "scope": "#/properties/Role" }
                ],
                "properties": {
                    "Name": { "type": "string", "ui": { "label": "Name" } },
                    "Role": { "type": "string", "ui": { "label": "Role" } }
                }
            }
        }
    }
}
