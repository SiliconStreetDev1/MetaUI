                "group": "Contact Details"
            }
        },
        "Department": {
            "type": "string",
            "ui": {
                "label": "Department",
                "widget": "dropdown",
                "group": "Role Specifics"
            },
            "valueHelp": [
                { "key": "Engineering", "text": "Engineering" },
                { "key": "Sales", "text": "Sales" },
                { "key": "HR", "text": "Human Resources" }
