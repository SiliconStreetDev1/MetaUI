{
    "type": "object",
    "title": "Employee Onboarding Wizard",
    "layoutStrategy": "wizard",
    "properties": {
        "FirstName": {
            "type": "string",
            "required": true,
            "ui": {
                "label": "First Name",
                "group": "Personal Information"
            }
        },
        "LastName": {
            "type": "string",
            "required": true,
            "ui": {
                "label": "Last Name",
                "group": "Personal Information"
            }
        },
        "Email": {
            "type": "string",
            "required": true,
            "validations": ["email"],
            "ui": {
                "label": "Work Email",
                "group": "Contact Details"
            }
        },
        "Phone": {
            "type": "string",
            "ui": {
