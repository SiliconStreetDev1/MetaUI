        "HasPortalAccess": false
      }
    ]
  },
  "schema": {
    "openapi": "3.0.0",
    "info": {
      "title": "Customer Profile",
      "version": "1.0.0"
    },
    "components": {
      "schemas": {
        "Root": {
          "type": "object",
          "properties": {
            "CustomerName": {
              "type": "string",
              "maxLength": 50,
              "ui": {
                "label": "Customer Name",
                "isKey": true
              }
            },
            "IsActive": {
              "type": "boolean",
              "ui": {
                "label": "Account Active"
              }
            },
            "Comments": {
              "type": "string",
              "ui": {
                "label": "Additional Notes",
                "rows": 4,
                "fullWidth": true
              }
            },
            "AccountType": {
              "type": "string",
              "valueHelp": [
                {
                  "key": "BASIC",
                  "text": "Basic Plan"
                },
                {
                  "key": "PREMIUM",
                  "text": "Premium Plan"
                },
                {
                  "key": "CORPORATE",
                  "text": "Corporate Plan"
                }
              ],
              "ui": {
                "label": "Account Type"
              }
            },
            "CreditLimit": {
              "type": "number",
              "scale": 2,
              "ui": {
                "label": "Credit Limit (USD)",
                "visibleOn": "$root.IsActive === true"
              }
            },
            "CreationDate": {
              "type": "string",
              "ui": {
                "label": "Creation Date",
                "readOnly": true
              },
              "format": "date"
            },
            "Attachment": {
              "type": "string",
              "ui": {
                "label": "Supporting Document"
              }
            },
            "AccessRegions": {
              "type": "array",
              "enum": [
                "North America",
                "Europe",
                "Asia",
                "Oceania"
              ],
              "ui": {
                "label": "Access Regions"
              }
            },
            "Discount": {
              "type": "number",
              "minimum": 0,
              "maximum": 50,
              "multipleOf": 5,
              "ui": {
                "label": "Discount % (Max 50%)"
              }
            },
            "ClientRating": {
              "type": "number",
              "maximum": 5,
              "ui": {
                "label": "Client Rating"
              }
            },
            "AlertMsg": {
              "type": "string"
            },
            "Website": {
              "type": "string",
              "ui": {
                "label": "Corporate Website"
              },
              "format": "uri"
            },
            "IBAN": {
              "type": "string",
              "ui": {
                "label": "Bank Account (IBAN)"
              }
            },
            "LicenseCode": {
              "type": "string",
              "minLength": 7,
              "pattern": "^[A-Z]{3}-\\d{3}$",
              "ui": {
                "label": "License Code (ABC-123)"
              }
            },
            "SupportPhone": {
              "type": "string",
              "ui": {
                "label": "Support Phone",
                "formatter": "phone"
              }
            },
            "ActionRow": {
              "type": "string",
              "ui": {
                "label": "Navigate to Corporate",
                "args": "https://sap.com"
              }
            },
            "ContactEmail": {
              "type": "string",
              "ui": {
                "label": "Contact Email"
              },
              "format": "email"
            },
            "Revenue": {
              "type": "number",
              "ui": {
                "label": "Projected Revenue",
                "formatter": "currency"
              }
            },
            "LiveCountries": {
              "type": "string",
              "ui": {
                "label": "Live Country Search (Async)"
              }
            },
            "ResetData": {
              "type": "string",
              "ui": {
                "label": "Danger Zone"
              }
            },
            "MeetingTime": {
              "type": "string",
              "ui": {
                "label": "Meeting Time"
              }
            },
            "LastLogin": {
              "type": "string",
              "ui": {
                "label": "Last Login Timestamp",
                "readOnly": true
              },
              "format": "date-time"
            },
            "Contacts": {
              "type": "array",
              "ui": {
                "label": "Authorized Contacts"
              },
              "items": {
                "type": "object",
                "properties": {
                  "ContactID": {
                    "type": "string",
                    "ui": {
                      "label": "ID",
                      "isKey": true,
                      "readOnly": true
                    }
                  },
                  "FullName": {
                    "type": "string",
                    "maxLength": 100,
                    "ui": {
                      "label": "Full Name"
                    }
                  },
                  "Role": {
                    "type": "string",
                    "valueHelp": [
                      {
                        "key": "ADMIN",
                        "text": "Administrator"
                      },
                      {
                        "key": "BILLING",
                        "text": "Billing Contact"
                      }
                    ],
                    "ui": {
                      "label": "Role"
                    }
                  },
                  "HasPortalAccess": {
                    "type": "boolean",
                    "ui": {
                      "label": "Portal Access"
                    }
                  }
                },
                "required": [
                  "ContactID",
                  "FullName",
                  "Role"
                ]
              }
            }
          },
          "required": [
            "CustomerName",
            "AccountType",
            "CreditLimit",
            "ContactEmail",
            "MeetingTime"
          ]
        }
      }
    }
  }
}