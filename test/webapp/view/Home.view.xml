<mvc:View
    controllerName="metaui.sandbox.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f">
    
    <Page title="MetaUI Launchpad">
        <content>
            <VBox class="sapUiMediumMargin">
                <Title text="Select a Demonstration Scenario" level="H2" class="sapUiSmallMarginBottom" />
                <HBox wrap="Wrap">
                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="The 'Everything' Form" subheader="All Plugins" press=".onNavToScenario" width="200px">
                        <customData>
                            <sap.ui.core:CustomData xmlns:sap.ui.core="sap.ui.core" key="scenario" value="everything" />
                        </customData>
                        <TileContent>
                            <NumericContent value="1" icon="sap-icon://form" />
                        </TileContent>
                    </GenericTile>

                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="String Binding" subheader="initialDataJson" press=".onNavToScenario" width="200px">
                        <customData>
                            <sap.ui.core:CustomData xmlns:sap.ui.core="sap.ui.core" key="scenario" value="string" />
                        </customData>
                        <TileContent>
                            <NumericContent value="2" icon="sap-icon://syntax" />
                        </TileContent>
                    </GenericTile>

                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="JS API Dialog" subheader="Programmatic" press=".onNavToScenario" width="200px">
                        <customData>
                            <sap.ui.core:CustomData xmlns:sap.ui.core="sap.ui.core" key="scenario" value="dialog" />
                        </customData>
                        <TileContent>
                            <NumericContent value="3" icon="sap-icon://popup-window" />
                        </TileContent>
                    </GenericTile>

                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Schema Inference" subheader="No Schema Provided" press=".onNavToScenario" width="200px">
                        <customData>
                            <core:CustomData key="scenario" value="inference" />
                        </customData>
                        <TileContent>
                            <NumericContent value="4" icon="sap-icon://chain-link" />
                        </TileContent>
                    </GenericTile>

                    <GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="Complex Hierarchy" subheader="Nested Tables &amp; Dialogs" press=".onNavToScenario" width="200px">
                        <customData>
                            <core:CustomData key="scenario" value="complex" />
                        </customData>
                        <TileContent>
                            <NumericContent value="5" icon="sap-icon://hierarchy" />
                        </TileContent>
                    </GenericTile>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
