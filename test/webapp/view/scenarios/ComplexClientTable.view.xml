<mvc:View
    controllerName="metaui.sandbox.controller.scenarios.ComplexClientTable"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:meta="nz.co.siliconst.ui5.metaui.controls"
    xmlns:codeeditor="sap.ui.codeeditor"
    xmlns:l="sap.ui.layout"
    xmlns="sap.m">
    <Page title="Scenario: Complex Client Table" showNavButton="true" navButtonPress=".onNavBack">
        <headerContent>
            <Switch state="{viewModel>/displayMode}" customTextOn="Display" customTextOff="Edit" tooltip="Toggle Display Mode" />
            <Switch state="{viewModel>/liveUpdate}" customTextOn="Live" customTextOff="Manual" tooltip="Toggle Live JSON Updates" />
            <Button text="Regenerate UI" icon="sap-icon://refresh" press=".onRegeneratePress" />
            <Button text="Add New Row" icon="sap-icon://add" press=".onAddRow" type="Emphasized" />
            <Button text="Force Extract Data" icon="sap-icon://download" press=".onExtractData" />
        </headerContent>
        <content>
            <l:Splitter height="100%" width="100%">
                <!-- Left Pane: Source Tab -->
                <VBox class="sapUiMediumMargin" height="100%" fitContainer="true">
                    <layoutData>
                        <l:SplitterLayoutData size="30%" />
                    </layoutData>
                    <IconTabBar stretchContentHeight="true" applyContentPadding="false" expanded="true">
                        <layoutData>
                            <FlexItemData growFactor="1" />
                        </layoutData>
                        <items>
                            <IconTabFilter text="Schema Definition">
                                <codeeditor:CodeEditor type="json" value="{viewModel>/editorSchemaString}" height="100%" editable="true" />
                            </IconTabFilter>
                            <IconTabFilter text="Global State View">
                                <codeeditor:CodeEditor type="json" value="{viewModel>/editorDataString}" change=".onInboundStringChange" height="100%" editable="true" />
                            </IconTabFilter>
                            <IconTabFilter text="Integration Examples">
                                <codeeditor:CodeEditor type="javascript" value="{viewModel>/codeExamples}" height="100%" editable="false" />
                            </IconTabFilter>
                        </items>
                    </IconTabBar>
                </VBox>

                <!-- Center Pane: Table -->
                <ScrollContainer height="100%" vertical="true" width="auto">
                    <layoutData>
                        <l:SplitterLayoutData size="auto" />
                    </layoutData>
                    <VBox class="sapUiMediumMargin">
                        <MessageStrip
                            text="Compact Layout with Schema: Notice how the DynamicHost renders a dense layout with a schema inside a table cell. Sub-arrays get extracted to a nested table."
                            type="Success"
                            showIcon="true"
                            class="sapUiSmallMarginBottom" />

                        <Table id="clientTable" items="{viewModel>/records}" noDataText="No records available">
                            <columns>
                                <Column width="60px"><Text text="ID" /></Column>
                                <Column width="150px"><Text text="Name" /></Column>
                                <Column><Text text="Metadata (DynamicHost + Schema)" /></Column>
                                <Column width="80px" hAlign="End"><Text text="Actions" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{viewModel>id}" />
                                        <Input value="{viewModel>name}" />
                                        
                                        <!-- String double binding with schema -->
                                        <meta:DynamicHost
                            fieldChange=".onFieldChange" 
                                            schemaDefinition="{viewModel>/schemaDefinition}" 
                                            dataJson="{viewModel>metadataString}" 
                                            liveUpdate="{viewModel>/liveUpdate}"
                                            displayMode="{viewModel>/displayMode}" />
                                        
                                        <Button icon="sap-icon://delete" type="Reject" press=".onDeleteRow" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </ScrollContainer>

                </l:Splitter>
        </content>
    </Page>
</mvc:View>
